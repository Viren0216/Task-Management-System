// This is your Prisma schema file.
// It acts as the single source of truth for your database models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Model placeholders - We will populate this with User, Project, Task models in the coming steps

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  avatar       String?
  bio          String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens   RefreshToken[]
  ownedProjects   Project[]       @relation("ProjectOwner")
  updatedProjects Project[]       @relation("ProjectUpdater")
  projectMembers  ProjectMember[] @relation("ProjectMemberUser")
  invitedMembers  ProjectMember[] @relation("ProjectMemberInviter")
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  updatedBy User?           @relation("ProjectUpdater", fields: [updatedById], references: [id])
  members   ProjectMember[]
  tasks     Task[]          @relation("ProjectTasks")

  @@unique([ownerId, name])
  @@index([ownerId])
}

model ProjectMember {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  role        ProjectRole @default(MEMBER)
  invitedById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("ProjectMemberInviter", fields: [invitedById], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
  @@index([projectId, role])
}

enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

model Task {
  id          String       @id @default(uuid())
  projectId   String
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  createdById String
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project   Project @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User    @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
