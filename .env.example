# Application Port
PORT=5000

# Environment Name
NODE_ENV=development

# Database Connection (MySQL)
# Important: Update username, password, host, port, and database name based on your local MySQL setup
DATABASE_URL="mysql://root:password@localhost:3306/task_management_db"

# JWT Secrets - In production, these should be long random cryptographically secure strings
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
